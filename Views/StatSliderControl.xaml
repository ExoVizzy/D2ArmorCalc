<!--
*   FILE          : StatSliderControl.xaml
*   PROJECT       : D2ArmorCalc
*   PROGRAMMER    : ExoVizzy
*   FIRST VERSION : May 17, 2026
*   DESCRIPTION   : Reusable UserControl for single stat row, containing
*                   enable checkbox, stat label, min textbox, range slider,
*                   & max textbox with two-way live binding.
-->
<UserControl x:Class="D2ArmorCalc.StatSliderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:D2ArmorCalc">

    <Grid Margin="0,4,0,4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="24"   />
            <!-- Checkbox -->
            <ColumnDefinition Width="80"   />
            <!-- Stat label -->
            <ColumnDefinition Width="60"   />
            <!-- Min label + textbox -->
            <ColumnDefinition Width="*"    />
            <!-- Slider -->
            <ColumnDefinition Width="60"   />
            <!-- Max label + textbox -->
        </Grid.ColumnDefinitions>

        <!-- Enable Checkbox -->
        <CheckBox Grid.Column="0"
                  Style="{StaticResource ToggleCheckBox}"
                  IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                  VerticalAlignment="Center" />

        <!-- Stat Label -->
        <TextBlock Grid.Column="1"
                   Style="{StaticResource BodyText}"
                   Text="{Binding Label}"
                   VerticalAlignment="Center"
                   Margin="6,0,0,0" />

        <!-- Min Input -->
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0">
            <TextBlock Text="Min:"
                       Style="{StaticResource SecondaryText}"
                       VerticalAlignment="Center"
                       Margin="0,0,4,0" />
            <TextBox Width="38"
                     Style="{StaticResource InputTextBox}"
                     Text="{Binding MinValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding IsEnabled}"
                     VerticalAlignment="Center" />
        </StackPanel>

        <!-- Range Slider -->
        <local:RangeSlider Grid.Column="3"
                           MinValue="{Binding MinSlider, Mode=TwoWay}"
                           MaxValue="{Binding MaxSlider, Mode=TwoWay}"
                           Stat="{Binding Stat}"
                           IsEnabled="{Binding IsEnabled}"
                           VerticalAlignment="Center"
                           Margin="4,0,4,0" />

        <!-- Max Input -->
        <StackPanel Grid.Column="4"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="8,0,0,0">
            <TextBlock Text="Max:"
                       Style="{StaticResource SecondaryText}"
                       VerticalAlignment="Center"
                       Margin="0,0,4,0" />
            <TextBox Width="38"
                     Style="{StaticResource InputTextBox}"
                     Text="{Binding MaxValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding IsEnabled}"
                     VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>