<Application x:Class="D2ArmorCalc.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:D2ArmorCalc"
             StartupUri="Views/D2ArmorCalc.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <local:BoolToVisibilityConverter          x:Key="BoolToVisibility"        />
            <local:NonZeroToVisibilityConverter       x:Key="NonZeroToVisibility"     />
            <local:IsNegativeConverter                x:Key="IsNegativeConverter"     />
            <local:InverseBoolToVisibilityConverter   x:Key="InverseBoolToVisibility" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
